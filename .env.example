# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=dragonbytes-ctf
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@dragonbytes-ctf.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_LONG_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Seed secret: any string you choose — used once to populate Firestore ──────
SEED_SECRET=pick-any-random-string-here

# ── Admin panel: comma-separated Firebase Auth emails allowed to create/delete
#    Competition Rooms and add questions to them ────────────────────────────
ADMIN_EMAILS=you@example.com,co-organizer@example.com
