# ── Clerk (copy from: clerk.com → Your App → API Keys) ──────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase Admin (copy from: Firebase Console → Project Settings → Service Accounts → Generate Key) ──
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Seed secret: any string you choose, used ONCE to populate Firestore ──
SEED_SECRET=pick-any-secret-string
